{
  "name": "sapphire",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A fast, simple, local-first dev workspace for Mac: Markdown notes, a task board, and GitHub PRs.",
  "author": "Aidan Garske",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "setup": "bash scripts/install-mac.sh",
    "app": "bash scripts/build-app.sh",
    "app:install": "bash scripts/build-app.sh --install",
    "tauri": "tauri"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@lezer/highlight": "^1.2.3",
    "@lezer/markdown": "^1.6.4",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2",
    "codemirror": "^6.0.2",
    "dompurify": "^3.4.11",
    "lucide-preact": "^1.18.0",
    "markdown-it": "^14.2.0",
    "markdown-it-task-lists": "^2.1.1",
    "preact": "^10.25.1"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.9.3",
    "@tauri-apps/cli": "^2",
    "@types/dompurify": "^3.0.5",
    "@types/markdown-it": "^14.1.2",
    "prettier": "^3.8.4",
    "sharp": "^0.35.1",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vitest": "^4.1.9"
  }
}

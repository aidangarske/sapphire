{
  "name": "sapphire",
  "version": "0.2.0",
  "type": "module",
  "description": "A fast, lightweight terminal workspace: Markdown notes, a task board, and GitHub PRs. Runs anywhere.",
  "author": "Aidan Garske",
  "license": "MIT",
  "bin": {
    "sapphire": "./bin/sapphire.js"
  },
  "files": [
    "bin",
    "src"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "start": "bun run src/index.ts",
    "test": "bun test src/core src/tui",
    "typecheck": "tsc --noEmit",
    "build": "bun build src/index.ts --compile --outfile dist/sapphire",
    "build:all": "bash scripts/build-binaries.sh"
  },
  "dependencies": {
    "ink": "^7.1.0",
    "react": "^19.2.7",
    "react-devtools-core": "^6.1.5",
    "string-width": "^7.2.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@types/react": "^19.2.0",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5.6.2"
  }
}
